# PostgreSQL Message Store (the scraper's DB on Railway).
# The Digest Service is a read-only consumer — see docs/adr/0001-*.
DATABASE_URL=

# LLM — any OpenAI-compatible chat-completions endpoint (OpenRouter or similar).
# LLM_BASE_URL is the base up to /v1; the code appends /chat/completions.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=anthropic/claude-sonnet-4.6

# Telegram bot that posts the digest, and the destination channel/chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_DIGEST_CHAT_ID=
